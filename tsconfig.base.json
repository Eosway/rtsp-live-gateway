{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@rtsp-gateway/protocol": ["packages/protocol/src/index.ts"],
      "@rtsp-gateway/client": ["packages/client/src/index.ts"],
      "@rtsp-gateway/player-vue": ["packages/player-vue/src/index.ts"]
    }
  }
}
