{
  "name": "@eosway/rtsp-live-gateway-server",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --on-success \"node dist/index.js\"",
    "tsc": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "start": "node dist/index.js",
    "release": "commit-and-tag-version --path . -t server@"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.15"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@eosway/rtsp-live-gateway-protocol": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  }
}
