{
  "name": "@eosway/rtsp-live-gateway-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @eosway/rtsp-live-gateway-protocol build && pnpm --filter @eosway/rtsp-live-gateway-client build && pnpm --filter @eosway/rtsp-live-gateway-server build && pnpm --filter @eosway/rtsp-live-gateway-player-vue build",
    "build:all": "pnpm run build && pnpm --filter @eosway/rtsp-live-gateway-playground build",
    "build:server": "pnpm --filter @eosway/rtsp-live-gateway-protocol build && pnpm --filter @eosway/rtsp-live-gateway-server build",
    "tsc": "pnpm -r --if-present tsc",
    "test": "pnpm -r --if-present test",
    "clean": "pnpm -r --if-present clean",
    "lint": "eslint --fix .",
    "format": "prettier --write .",
    "dev:playground": "pnpm --filter @eosway/rtsp-live-gateway-playground dev",
    "pack:player": "pnpm --filter @eosway/rtsp-live-gateway-player-vue pack",
    "docker:build": "bash scripts/build-server-image.sh",
    "docker:export": "bash scripts/export-server-image.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsdown": "^0.16.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vue-eslint-parser": "^10.4.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(*.js|*.mjs|*.cjs|*.ts|*.mts|*.cts|*.vue)": [
      "prettier --write --ignore-unknown"
    ]
  }
}
