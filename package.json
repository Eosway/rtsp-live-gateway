{
  "name": "rtsp-live-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @rtsp-gateway/protocol build && pnpm --filter @rtsp-gateway/client build && pnpm --filter @rtsp-gateway/server build && pnpm --filter @rtsp-gateway/player-vue build",
    "build:all": "pnpm run build && pnpm --filter @rtsp-gateway/playground build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "clean": "pnpm -r --if-present clean",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:playground": "pnpm --filter @rtsp-gateway/playground dev",
    "pack:player": "pnpm --filter @rtsp-gateway/player-vue pack",
    "docker:server": "docker build -f apps/server/Dockerfile -t rtsp-gateway-server:local .",
    "docker:server:alpine": "docker build -f apps/server/Dockerfile.alpine -t rtsp-gateway-server:alpine .",
    "export:server-image": "bash scripts/export-server-image.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsdown": "^0.16.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vue-eslint-parser": "^10.4.0"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(*.js|*.mjs|*.cjs|*.ts|*.mts|*.cts|*.vue)": [
      "prettier --write --ignore-unknown"
    ]
  }
}
