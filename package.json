{
  "name": "rtsp-live-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @rtsp-gateway/protocol build && pnpm --filter @rtsp-gateway/client build && pnpm --filter @rtsp-gateway/server build && pnpm --filter @rtsp-gateway/player-vue build",
    "build:all": "pnpm run build && pnpm --filter @rtsp-gateway/playground build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "clean": "pnpm -r --if-present clean",
    "dev:playground": "pnpm --filter @rtsp-gateway/playground dev",
    "pack:player": "pnpm --filter @rtsp-gateway/player-vue pack",
    "docker:server": "docker build -f apps/server/Dockerfile -t rtsp-gateway-server:local .",
    "docker:server:alpine": "docker build -f apps/server/Dockerfile.alpine -t rtsp-gateway-server:alpine .",
    "export:server-image": "bash scripts/export-server-image.sh"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "tsdown": "^0.16.6",
    "typescript": "^5.8.3",
    "vite": "^8.0.9"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.0.0"
  }
}
